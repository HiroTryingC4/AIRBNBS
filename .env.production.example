# Production Environment Variables for Vercel Deployment

# Database Configuration (PostgreSQL)
# Get this from your database provider (Supabase, PlanetScale, Neon, etc.)
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# NextAuth Configuration
# Replace with your actual Vercel domain
NEXTAUTH_URL="https://your-app-name.vercel.app"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here-32-chars-minimum"

# Vercel Blob Storage (for image uploads)
# Get this from Vercel Dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# Application Configuration
NODE_ENV="production"