# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/airbnb_platform"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Vercel Blob Storage (for image uploads)
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token-here"

# External Calendar Sync (Optional - for Phase 2)
# GOOGLE_CALENDAR_API_KEY="your-google-calendar-api-key"
# AIRBNB_CALENDAR_SYNC_URL="your-airbnb-calendar-ical-url"

# Application Configuration
NODE_ENV="development"
